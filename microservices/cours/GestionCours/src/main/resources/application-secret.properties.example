# Copiez ce fichier vers application-secret.properties (même dossier).
# Le fichier application-secret.properties est ignoré par Git : vous y mettez la vraie clé Groq.
#
# Une seule ligne, la clé directement après le = (PAS de ${ } autour) :
# openai.api.key=gsk-votre-cle-groq
#
# Alternative : variable d'environnement OPENAI_API_KEY=gsk-... (Spring Boot la lie à openai.api.key).

openai.api.key=

# ElevenLabs (voix de la présentation PDF) — une seule ligne ; ne pas dupliquer la clé avec une ligne vide en dessous
# (la dernière valeur gagne et une ligne vide efface la clé).
elevenlabs.api.key=sk_f0369353e2902a67d0f8136758eefab28d9f53c0950b6a0e
# ou variable d'environnement ELEVENLABS_API_KEY=sk_...
# Après configuration : redémarrer GestionCours, puis « Régénérer » la présentation (réimporter le PDF).
